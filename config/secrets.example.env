# Copy this file to config/secrets.env and fill in real values.
# config/secrets.env is gitignored - never commit real credentials.

# --- Spotify (https://developer.spotify.com/dashboard) ---
# Create an app, add http://127.0.0.1:8080/callback as a Redirect URI,
# and requires a Spotify PREMIUM account for playback control.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/callback

# Name librespot advertises on the network (Settings > Devices in Spotify
# app should show this name once librespot is running).
SPOTIFY_DEVICE_NAME=mini-vinyl

# --- Bluetooth speaker ---
# MAC address of the paired/trusted speaker, e.g. AA:BB:CC:DD:EE:FF
BLUETOOTH_SPEAKER_MAC=

# mpv audio output. PipeWire (default on Raspberry Pi OS Bookworm/Trixie)
# handles Bluetooth A2DP itself, so audio just needs to go to the PipeWire
# sink - no bluealsa needed. Leave as "pipewire" unless you've set up
# something custom.
AUDIO_OUTPUT=pipewire

# --- NFC reader ---
# i2c is the simplest wiring (VCC, GND, SDA, SCL) and is what nfc_reader.py
# uses by default.
PN532_IRQ_PIN=16
PN532_RESET_PIN=12
